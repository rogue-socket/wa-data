# Copy this file to user.env and customize values for your machine.

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000/ingest
BACKEND_REACTIONS_URL=http://127.0.0.1:8000/reactions/ingest
BACKEND_COMMAND_NEXT_URL=http://127.0.0.1:8000/bot/commands/next
BACKEND_COMMAND_RESULT_URL=http://127.0.0.1:8000/bot/commands

# Bot
WA_CLIENT_ID=wa-data-bot
WA_INIT_RETRIES=5
COMMAND_POLL_INTERVAL_MS=3000
WA_HEADLESS=true
WA_NO_SANDBOX=false
WA_DISABLE_SETUID_SANDBOX=true
WA_DISABLE_DEV_SHM_USAGE=true
WA_DISABLE_GPU=true
# Optional: point to system Chrome/Chromium binary if needed
WA_CHROME_EXECUTABLE_PATH=

# Optional category classifier fallback (cost-controlled)
ENABLE_GEMINI_CLASSIFIER=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_CONFIDENCE_THRESHOLD=0.62

# Optional 2-day Gemini batch re-classifier (low-token mode)
GEMINI_BATCH_ENABLED=true
GEMINI_BATCH_DAYS=2
GEMINI_BATCH_LIMIT=1200
GEMINI_BATCH_CHUNK_SIZE=30
GEMINI_BATCH_MODEL=gemini-2.0-flash-lite
GEMINI_BATCH_MAX_OUTPUT_TOKENS=900
GEMINI_BATCH_TIMEOUT_SECONDS=12
GEMINI_BATCH_CATEGORY_VERSION=v1-gemini-batch-lite
# Optional pricing (per 1M tokens) for cost estimates in batch output
GEMINI_BATCH_INPUT_COST_PER_MTOKENS_USD=0
GEMINI_BATCH_OUTPUT_COST_PER_MTOKENS_USD=0
# Optional overrides for spec files
# GEMINI_BATCH_TAXONOMY_PATH=/absolute/path/to/taxonomy.jsonl
# GEMINI_BATCH_PROMPT_PATH=/absolute/path/to/prompt_skeleton.txt
